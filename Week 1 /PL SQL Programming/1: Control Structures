DECLARE
    -- Cursor to fetch loans with customer birth date
    CURSOR c_senior_loans IS
        SELECT l.LoanID, l.InterestRate, c.DOB
        FROM Loans l
        JOIN Customers c ON l.CustomerID = c.CustomerID;
    
    v_age NUMBER;
BEGIN
    FOR r_loan IN c_senior_loans LOOP
        -- Calculate current age based on Date of Birth
        v_age := FLOOR(MONTHS_BETWEEN(SYSDATE, r_loan.DOB) / 12);
        
        IF v_age > 60 THEN
            UPDATE Loans
            SET InterestRate = InterestRate - 1
            WHERE LoanID = r_loan.LoanID;
        END IF;
    END LOOP;
    COMMIT;
END;
/

