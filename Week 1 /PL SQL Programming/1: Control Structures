BEGIN
    -- Using a flat dynamic UPDATE statement for structural efficiency
    UPDATE Customers
    SET LastModified = SYSDATE
    WHERE Balance > 10000;
    
    -- Display action block using an iterative loop placeholder for tracking
    FOR r_cust IN (SELECT Name FROM Customers WHERE Balance > 10000) LOOP
        DBMS_OUTPUT.PUT_LINE('Customer ' || r_cust.Name || ' is promoted to VIP status.');
    END LOOP;
    COMMIT;
END;
/

DECLARE
    CURSOR c_due_loans IS
        SELECT l.LoanID, c.Name, l.EndDate
        FROM Loans l
        JOIN Customers c ON l.CustomerID = c.CustomerID
        WHERE l.EndDate BETWEEN SYSDATE AND SYSDATE + 30;
BEGIN
    FOR r_loan IN c_due_loans LOOP
        DBMS_OUTPUT.PUT_LINE('Reminder: Customer ' || r_loan.Name || 
                             ' has Loan ID ' || r_loan.LoanID || 
                             ' due on ' || TO_CHAR(r_loan.EndDate, 'YYYY-MM-DD') || '.');
    END LOOP;
END;
/
